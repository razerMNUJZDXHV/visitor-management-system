<navigation-bar id="navBar" />

<view class="page-container" style="padding-top: {{navHeight}}px;">
  <view wx:if="{{showNoShowPenaltyTip}}" class="ban-tip ban-tip-dismissible">
    <text class="ban-tip-text">提示：若您在一个月内连续爽约2次，将在三个月内被限制申请。</text>
    <text class="ban-tip-close" bindtap="handleCloseNoShowPenaltyTip">✕</text>
  </view>

  <scroll-view class="list-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{appointmentList.length === 0}}" class="empty">
      <text>暂无预约记录</text>
    </view>
    <view wx:else>
      <view class="appointment-item" wx:for="{{appointmentList}}" wx:key="appointmentId" bindtap="goDetail" data-id="{{item.appointmentId}}">
        <view class="item-header">
          <text class="status {{item.statusClass}}">{{item.statusText}}</text>
          <text class="apply-date">{{item.applyDateText}}</text>
        </view>
        <view class="item-content">
          <view class="row"><text class="label">预计到达时间：</text>{{item.expectedStartTimeText}}</view>
          <view class="row"><text class="label">预计离开时间：</text>{{item.expectedEndTimeText}}</view>
          <view class="row warning-row" wx:if="{{item.overstayHint}}">
            <text class="label">提醒：</text>{{item.overstayHint}}
          </view>
        </view>
        <view class="item-footer" catchtap="stopPropagation">
          <!-- 新增：预约失败时显示“查看原因”按钮 -->
          <button wx:if="{{item.status === 2 && item.rejectReason}}" size="mini" type="default" bindtap="handleViewReason" data-reason="{{item.rejectReason}}">查看原因</button>
          <!-- 预约成功才显示查看通行码按钮 -->
          <button wx:if="{{item.status === 1 || item.status === 4}}" size="mini" type="primary" bindtap="handleViewQRCode" data-item="{{item}}">通行码</button>
          <!-- 待审核/预约成功可取消 -->
          <button wx:if="{{item.status === 0 || item.status === 1}}" size="mini" type="warn" bindtap="handleCancel" data-id="{{item.appointmentId}}">取消预约</button>
        </view>
      </view>
    </view>

    <!-- 在页面底部添加弹窗，与原有内容平级 -->
    <view class="qr-modal" wx:if="{{showQrModal}}" catchtouchmove="preventMove">
      <view class="qr-mask" bindtap="closeQrModal"></view>
      <view class="qr-content">
        <view class="qr-header">
          <text class="qr-title">临时通行二维码</text>
        </view>
        <view class="qr-body">
          <image wx:if="{{qrCodeUrl}}" src="{{qrCodeUrl}}" mode="aspectFit" class="qr-image" />
          <view wx:else class="qr-loading">生成中...</view>
          <view class="qr-tip">
            <text>有效期：{{qrStartTime}} 至 {{qrEndTime}}</text>
            <text>已签到未签退且超过预计离开时间后，宽限30分钟</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>

<custom-tab-bar />