<navigation-bar id="navBar"/>

<view class="page-container" style="padding-top: {{navHeight}}px;">
  <!-- 顶部欢迎卡片 -->
  <view class="welcome-card">
    <view class="welcome-row">
      <text class="welcome-text">欢迎，审批人：{{approverName}}</text>
      <view class="pending-summary">
        <text class="summary-text">全部待审批 {{totalCount}} 条</text>
      </view>
    </view>
  </view>

  <scroll-view class="list-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 今日待审批（可折叠展开） -->
    <view wx:if="{{todayList.length > 0}}" class="group-section">
      <view class="group-header" bindtap="toggleTodayExpand">
        <text>今日待审批</text>
        <text class="expand-icon">{{todayExpanded ? '▼' : '▶'}}</text>
      </view>
      <block wx:if="{{todayExpanded}}">
        <view class="appointment-item" wx:for="{{todayList}}" wx:key="appointmentId" bindtap="goDetail" data-id="{{item.appointmentId}}">
          <view class="item-header">
            <text class="apply-date">{{item.createTimeText}}</text>
            <text class="status-badge status-pending">待审批</text>
          </view>
          <view class="item-content">
            <view class="row"><text class="label">访客姓名：</text>{{item.visitorName}}</view>
            <view class="row"><text class="label">手机号：</text>{{item.visitorPhone}}</view>
            <view class="row"><text class="label">到访时间：</text>{{item.expectedStartTimeText}}</view>
          </view>
        </view>
      </block>
    </view>

    <!-- 更早待审批 -->
    <view wx:if="{{earlierList.length > 0}}" class="group-section">
      <view class="group-header" bindtap="toggleEarlierExpand">
        <text>更早</text>
        <text class="expand-icon">{{earlierExpanded ? '▼' : '▶'}}</text>
      </view>
      <block wx:if="{{earlierExpanded}}">
        <view class="appointment-item" wx:for="{{earlierList}}" wx:key="appointmentId" bindtap="goDetail" data-id="{{item.appointmentId}}">
          <view class="item-header">
            <text class="apply-date">{{item.createTimeText}}</text>
            <text class="status-badge status-pending">待审批</text>
          </view>
          <view class="item-content">
            <view class="row"><text class="label">访客姓名：</text>{{item.visitorName}}</view>
            <view class="row"><text class="label">手机号：</text>{{item.visitorPhone}}</view>
            <view class="row"><text class="label">到访时间：</text>{{item.expectedStartTimeText}}</view>
          </view>
        </view>
      </block>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{todayList.length === 0 && earlierList.length === 0}}" class="empty">
      <text>暂无待审批申请</text>
    </view>
  </scroll-view>
</view>

<custom-tab-bar />