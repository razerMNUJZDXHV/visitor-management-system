<navigation-bar id="navBar" title="记录详情" />

<view class="page-container" style="padding-top: {{navHeight}}px;">
  <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="info-card">
      <view class="card-title">通行信息</view>
      <view class="info-row"><text class="label">记录ID：</text>{{detail.logId}}</view>
      <view class="info-row"><text class="label">预约ID：</text>{{detail.appointmentId || '无预约紧急登记'}}</view>
      <view class="info-row"><text class="label">通行类型：</text>{{detail.accessType === 1 ? '签到' : '签离'}}</view>
      <view class="info-row"><text class="label">核验方式：</text>{{detail.verifyMethod === 1 ? '扫码' : '手动'}}</view>
      <view class="info-row"><text class="label">通行时间：</text>{{detail.accessTime}}</view>
      <view class="info-row"><text class="label">紧急通行：</text>{{detail.emergency ? '是' : '否'}}</view>
    </view>

    <view class="info-card">
      <view class="card-title">访客信息</view>
      <view class="info-row"><text class="label">姓名：</text>{{detail.visitorName || '—'}}</view>
      <view class="info-row"><text class="label">手机号：</text>{{detail.visitorPhone || '—'}}</view>
      <view class="info-row"><text class="label">身份证号：</text>{{detail.visitorIdCard || '—'}}</view>
    </view>

    <view class="info-card">
      <view class="card-title">来访信息</view>
      <view class="info-row"><text class="label">来访事由：</text>{{detail.visitReason || '—'}}</view>
      <view class="info-row"><text class="label">授权审批人：</text>{{detail.authorizerName || '—'}}</view>
    </view>
  </scroll-view>
</view>
