<view class="tab-bar">
  <view 
    wx:for="{{list}}" 
    wx:key="index" 
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image class="icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}" />
    <text class="text">{{item.text}}</text>
  </view>
</view>